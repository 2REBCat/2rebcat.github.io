{{- $pages := slice -}}
{{- with site.GetPage "/about" -}}
  {{- $pages = $pages | append (dict
    "title" .Title
    "summary" ((.Summary | default (.Plain | truncate 180 "")) | plainify)
    "content" (.Plain | truncate 400 "")
    "section" "About"
    "url" .RelPermalink
    "date" ""
  ) -}}
{{- end -}}
{{- range site.RegularPages -}}
  {{- $pages = $pages | append (dict
    "title" .Title
    "summary" ((.Params.summary | default .Summary) | plainify | truncate 180 "")
    "content" (.Plain | truncate 400 "")
    "section" (cond .CurrentSection .CurrentSection.Title .Section)
    "url" .RelPermalink
    "date" (.Date.Format "2006.01.02")
  ) -}}
{{- end -}}
{{- $pages | jsonify -}}